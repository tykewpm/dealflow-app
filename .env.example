# Deal workspace data: `mock` (default) or `convex` (read-only snapshot; requires URL below).
VITE_DEAL_DATA_SOURCE=mock

# Convex deployment URL (Dashboard → Settings → Deploy key / URL). Required when using convex reads.
# VITE_CONVEX_URL=https://your-deployment.convex.cloud

# --- Convex backend (Dashboard → Settings → Environment Variables), not Vite ---
# Optional: allow `seed:seedDevWorkspace` on a prod-like deployment (`prod:...`). Not required for local/dev.
# ALLOW_CONVEX_DEV_SEED=true
#
# @convex-dev/auth requires JWT_PRIVATE_KEY + JWKS (+ CONVEX_SITE_URL). If JWKS is missing, run:
#   npm run convex:sync-jwks
# (reads JWT_PRIVATE_KEY from the deployment and sets JWKS to the matching public JWK set.)
